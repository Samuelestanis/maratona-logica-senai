programa {
  funcao inicio() {
    real c1,c2,c3,media

    escreva("Digite o consumo da primeira máquina (kWh):")
    leia(c1)
    escreva("Digite o consumo da segunda máquina (kWh):")
    leia(c2)
    escreva("Digite o consumo da terceira máquina (kWh):")
    leia(c3)

    media=(c1+c2+c3)/3

    escreva("A media de consumo em kWh é:", media)

    
  }
}
