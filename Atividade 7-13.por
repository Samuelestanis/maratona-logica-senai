programa {
  funcao inicio() {
    inteiro sa,sb

    escreva("Quantidade de peças produzidas pelo setor A:")
    leia(sa)
    escreva("Quantidade de peças produzidas pelo setor B:")
    leia(sb)

    se(sa>sb)
    escreva("O setor A produziu mais peças hoje")
    senao
    escreva("O setor B produziu mais peças hoje")
    
  }
}
